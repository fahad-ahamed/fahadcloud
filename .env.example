# ============================================
# FahadCloud - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- Database -----
# SQLite database path (use absolute path in production)
DATABASE_URL="file:./db/fahadcloud.db"

# ----- Authentication -----
# JWT secret key - MUST be changed in production!
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string

# ----- Server -----
# Your server's public IP (used for DNS/hosting config)
SERVER_IP=your-server-ip
PORT=3000

# ----- SMTP Email (Required for OTP verification) -----
# Gmail example. Use any SMTP provider you prefer.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# ----- bKash Payment Gateway (Optional) -----
# Leave empty to disable bKash payments
BKASH_API_KEY=
BKASH_API_SECRET=
BKASH_API_URL=https://checkout.pay.bka.sh/v1.2.0-beta
BKASH_MERCHANT_NUMBER=

# ----- Currency -----
USD_TO_BDT=110
