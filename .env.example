# FahadCloud Environment Configuration
# Copy this file to .env and fill in your values

# Server
NODE_ENV=production
PORT=3000
SERVER_IP=your-server-ip
HOSTNAME=0.0.0.0
PROJECT_ROOT=/home/fahad/fahadcloud

# Database (PostgreSQL)
DATABASE_URL=postgresql://fahadcloud:your_secure_password@localhost:5432/fahadcloud
DB_POOL_SIZE=5

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT Secret (MUST be a strong random string in production — at least 64 characters!)
# Generate with: openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-64-chars

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=FahadCloud
SMTP_FROM_EMAIL=your-email@gmail.com

# Admin
ADMIN_EMAILS=admin@fahadcloud.com
OWNER_EMAIL=admin@fahadcloud.com
ADMIN_DEFAULT_BALANCE=0
DEFAULT_STORAGE_LIMIT=107374182400

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=https://fahadcloud.com,https://www.fahadcloud.com
# CORS_ORIGIN — leave empty in production for strict same-origin policy
CORS_ORIGIN=

# bKash Payment
BKASH_API_KEY=
BKASH_API_SECRET=
BKASH_MERCHANT_NUMBER=
BKASH_API_URL=https://checkout.pay.bka.sh/v1.2.0-beta

# Currency
USD_TO_BDT=110

# Qdrant Vector DB (optional)
QDRANT_URL=http://localhost:6333

# HTTPS
ENFORCE_HTTPS=true

# Hosting Directories
HOSTING_BASE_DIR=/home/fahad/hosting
HOSTING_USERS_DIR=/home/fahad/hosting/users
HOSTING_SSL_DIR=/home/fahad/hosting/ssl
HOSTING_NGINX_DIR=/home/fahad/hosting/nginx

# DNS Directories
DNS_ZONES_DIR=/home/fahad/dns/zones
DNS_CONFIG_DIR=/home/fahad/dns/config
DNS_DNSMASQ_CONF=/home/fahad/dns/dnsmasq.conf
DNS_DNSMASQ_HOSTS=/home/fahad/dns/hosts
