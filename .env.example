# FahadCloud Environment Configuration
# Copy this file to .env and fill in your values

# Server
NODE_ENV=production
PORT=3000
SERVER_IP=your-server-ip
HOSTNAME=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://fahadcloud:your_secure_password@localhost:5432/fahadcloud

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT Secret (MUST be a strong random string in production!)
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-64-chars

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=FahadCloud
SMTP_FROM_EMAIL=your-email@gmail.com

# Admin
ADMIN_EMAILS=admin@fahadcloud.com
OWNER_EMAIL=admin@fahadcloud.com

# bKash Payment
BKASH_API_KEY=
BKASH_API_SECRET=
BKASH_MERCHANT_NUMBER=
BKASH_API_URL=https://checkout.pay.bka.sh/v1.2.0-beta

# Currency
USD_TO_BDT=110

# Qdrant Vector DB (optional)
QDRANT_URL=http://localhost:6333

# HTTPS
ENFORCE_HTTPS=true
